# ------------------------------------------------------------
# Python caches and test tooling
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.ipynb_checkpoints/

# ------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------
# Editor, OS, and local workspace metadata
# ------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
.agents/
.codex/
docs/

# ------------------------------------------------------------
# Native build output
# Keep root build scripts tracked; ignore generated build trees.
# ------------------------------------------------------------
build/
cmake-build-*/

# ------------------------------------------------------------
# Runtime-generated data and validation artifacts
# Keep source metadata tracked; ignore generated outputs.
# ------------------------------------------------------------
data/
reports/final_reports/
reports/preprocessing_validation/
reports/onnx_c_runtime_validation/
validation_dataset/reports/

# Generated top-level reports
reports/*.json

# ------------------------------------------------------------
# Model caches and failed export scratch space
# Keep intentional release artifacts tracked unless explicitly excluded.
# ------------------------------------------------------------
models/torchxrayvision_cache/
models/failed_exports/

# ------------------------------------------------------------
# Packaging and compiled distribution artifacts
# Keep installer/source packaging definitions tracked.
# ------------------------------------------------------------
dist/
package/output/
package/app/

# ------------------------------------------------------------
# Downloaded third-party runtime bundles
# ------------------------------------------------------------
third_party/onnxruntime/

# ------------------------------------------------------------
# Temporary diagnostics and logs
# ------------------------------------------------------------
tmp_onnx_diagnostics/
*.log
*.tmp
*.temp
